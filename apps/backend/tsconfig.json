{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": [
            "node",
            "express",
            "react",
            "react-dom"
        ],
        "rootDir": ".",
        "outDir": "dist",
        "jsx": "react-jsx"
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "types/**/*.d.ts",
        "assets/**/*",
        "drizzle.config.ts"
    ],
     "exclude": ["node_modules"]
}